# Jira (skip if Atlassian MCP is connected in your Claude Code)
JIRA_EMAIL=
JIRA_API_TOKEN=

# Web app base URL used by `xera:auth-setup` (Playwright launches the browser
# directly, not via playwright.config.ts, so relative `page.goto('/login')`
# needs this). `xera:exec` overrides via its own env injection.
XERA_BASE_URL=http://localhost:5173

# Test user credentials (one pair per role)

TEST_ADMIN_EMAIL=
TEST_ADMIN_PWD=

TEST_REGULAR_EMAIL=
TEST_REGULAR_PWD=


# xera auth state encryption key — DO NOT regenerate or .xera/.auth/ cache becomes useless
XERA_AUTH_KEY=6ad750461d1ed5acf8eb01c5fd47cedf17695b2d4f6764a732bc7de3f6064b66
